{
    "manifest_version": 3,
    "name": "MathBridge - AI Formula Copier",
    "short_name": "MathBridge",
    "version": "1.0.0",
    "version_name": "1.0.0 Stable",
    "description": "Easily copy math formulas from Gemini, ChatGPT, Claude, Perplexity, and DeepSeek to MathML (MS Word), LaTeX, Plain Text, or Image.",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "clipboardWrite",
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "MathBridge Settings"
    },
    "host_permissions": [
        "*://*.gemini.google.com/*",
        "*://*.chat.deepseek.com/*",
        "*://*.perplexity.ai/*",
        "*://*.chatgpt.com/*",
        "*://*.chat.openai.com/*",
        "*://*.claude.ai/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.gemini.google.com/*",
                "*://*.chat.deepseek.com/*",
                "*://*.perplexity.ai/*",
                "*://*.chatgpt.com/*",
                "*://*.chat.openai.com/*",
                "*://*.claude.ai/*"
            ],
            "js": [
                "katex.min.js",
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ]
}